<UserControl x:Class="IDBM_Final.Views.Title"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:IDBM_Final.Views"
               xmlns:vm="clr-namespace:IDBM_Final.ViewModels"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
    <UserControl.DataContext>
        <vm:TitleViewModel />
    </UserControl.DataContext>
    
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <ListBox Grid.Row="0"
            ItemsSource="{Binding Titles}"
          SelectedItem="{Binding SelectedTitle}"
          DisplayMemberPath="PrimaryTitle"      
          Width="300"
                 Height="300"/>
        
        <StackPanel Grid.Row="1"
            DataContext="{Binding SelectedTitle}">
            <TextBlock Text="Start Year:"/>
            <TextBlock Text="{Binding StartYear}"
                       VerticalAlignment="Top"
            HorizontalAlignment="Left"/>

            <TextBlock Text="End Year:"/>
            <TextBlock Text="{Binding EndYear}"/>

            <TextBlock Text="Episodes:" FontWeight="Bold"/>

            <ItemsControl ItemsSource="{Binding EpisodeParentTitles}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <TextBlock Text="{Binding Title.PrimaryTitle}"/>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </StackPanel>

    </Grid>
</UserControl>
