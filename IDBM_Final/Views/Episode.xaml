<UserControl x:Class="IDBM_Final.Views.Episode"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:IDBM_Final.Views"
             xmlns:vm="clr-namespace:IDBM_Final.ViewModels"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <StackPanel Orientation="Horizontal" Grid.Row="0">
            <TextBox Width="200"
                     Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"/>
        </StackPanel>
        <ListView
            ItemsSource="{Binding Episodes}"
            Grid.Row="1"
            Height="500"
             ScrollViewer.VerticalScrollBarVisibility="Auto">
            <ListView.View>
                <GridView>
                    <GridViewColumn Header="Title ID" Width="80" DisplayMemberBinding="{Binding Title.TitleId}"/>
                    <GridViewColumn Header="TitleName" Width="350" DisplayMemberBinding="{Binding Title.OriginalTitle}"/>
                    <GridViewColumn Header="EpisodeNumber" Width="350" DisplayMemberBinding="{Binding EpisodeNumber}"/>
                    <GridViewColumn Header="SeasonNumber" Width="80" DisplayMemberBinding="{Binding SeasonNumber}"/>
                </GridView>
            </ListView.View>
        </ListView>
        <StackPanel Grid.Row="2" Orientation="Horizontal">
            <TextBlock Text="Total Episodes: "/>
            <TextBlock Text="{Binding TotalEpisodes}"/>
        </StackPanel>

    </Grid>
</UserControl>
